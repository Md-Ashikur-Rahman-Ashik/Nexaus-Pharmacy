{
  "name": "Bangladesh Pharmacy Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": false
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "distribution": "temurin",
      "clean": true
    }
  },

  "postCreateCommand": "bash .devcontainer/setup_flutter.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "stdlib.dart",
        "usernamehw.errorlens",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },

  "forwardPorts": [8080]
}
